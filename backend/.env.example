# ── Local Code Execution ─────────────────────────────────────────────────
# Code runs on this machine. Override commands only if needed.
LOCAL_RUN_TIMEOUT_SECONDS=5
LOCAL_MAX_CODE_BYTES=200000
PYTHON_COMMAND=python
NODE_COMMAND=node
TSX_COMMAND=npx
TSX_ARGS=tsx

# ── CORS ────────────────────────────────────────────────────────────────
# Your local frontend URL
FRONTEND_URL=http://localhost:5173
